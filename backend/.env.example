# ═══════════════════════════════════════════════════════
# ROOTS ACROSS GENERATIONS — Backend Environment Variables
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in values.
# For production: set these in your hosting dashboard (Render, Railway, etc.)

# ── Database ──────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=

# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # Set to "production" on deploy

# ── CORS ──────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example: https://your-app.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ── JWT Secrets ───────────────────────────────────────
# Generate strong secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ── URL Configuration ─────────────────────────────────
# SERVER_URL  = This backend's public URL (used in Google OAuth callback)
# CLIENT_URL  = Frontend URL (Google OAuth redirects here after login)
# FRONTEND_URL = Frontend URL (used in shareable family links)
# BACKEND_URL  = This backend's public URL (used for local file upload fallback)
#
# Examples for production:
#   SERVER_URL=https://your-api.onrender.com
#   CLIENT_URL=https://your-app.vercel.app
#   FRONTEND_URL=https://your-app.vercel.app
#   BACKEND_URL=https://your-api.onrender.com
#
# Examples for local development:
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# ── Google OAuth ──────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs:
#   - https://your-api.onrender.com/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Firebase Storage (optional) ───────────────────────
# App falls back to local disk uploads if these are missing.
# Create at: https://console.firebase.google.com → Project Settings → Service Accounts
# Generate a new private key (JSON) and extract the values below.
# NOTE: In Firebase private keys, newlines appear as \n — keep them as-is.
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
